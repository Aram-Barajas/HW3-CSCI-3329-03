# ── 0. Imports & Seed ──────────────────────────────────────────────
import os
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
from sklearn.preprocessing import LabelEncoder, StandardScaler
from sklearn.impute import SimpleImputer
from sklearn.model_selection import RepeatedKFold, cross_val_score
from sklearn.linear_model import Perceptron, LogisticRegression
from sklearn.neighbors import KNeighborsClassifier
from sklearn.naive_bayes import GaussianNB
from sklearn.neural_network import MLPClassifier
from itertools import combinations

SEED = 17342

# ── 1. Load all subject Excel files ───────────────────────────────
data_folder = r"C:\Users\Aram\Downloads\IM-AccGyro\IM-AccGyro"  # <- UPDATE this to your path
subjects = sorted([d for d in os.listdir(data_folder) if d.startswith('Subject')])
activities = ['boxing', 'clapping', 'run', 'sitting', 'standing', 'walk']

all_data = []

for subj in subjects:
    subj_folder = os.path.join(data_folder, subj)
    if not os.path.isdir(subj_folder):
        continue
    for act in activities:
        # Find any Excel file containing the activity name
        files = [f for f in os.listdir(subj_folder) if act in f.lower() and f.endswith('.xlsx')]
        if len(files) == 0:
            print(f"Warning: no file found for {subj} {act}")
            continue
        file_path = os.path.join(subj_folder, files[0])
        df = pd.read_excel(file_path)
        df['subject'] = subj
        df['activity'] = act
        all_data.append(df)

full_df = pd.concat(all_data, ignore_index=True)
print("Combined dataset shape:", full_df.shape)

# ── 2. Preprocessing ─────────────────────────────────────────────
le = LabelEncoder()
full_df['activity_encoded'] = le.fit_transform(full_df['activity'])

# Select numeric features only
X = full_df.select_dtypes(include=np.number).copy()
y = full_df['activity_encoded']
feature_names = list(X.columns)

# Handle NaNs using mean imputation
imputer = SimpleImputer(strategy='mean')
X_imputed = imputer.fit_transform(X)

# Scale features
scaler = StandardScaler()
X_scaled = scaler.fit_transform(X_imputed)

# ── 2a. Class distribution plot ─────────────────────────────────
unique, counts = np.unique(y, return_counts=True)
labels = le.inverse_transform(unique)
plt.figure(figsize=(8,4))
plt.bar(labels, counts, color='steelblue', edgecolor='black')
plt.title('Class Distribution — IM-AccGyro Dataset (10 Subjects)')
plt.xlabel('Activity')
plt.ylabel('Count')
plt.tight_layout()
plt.savefig('class_distribution.png', dpi=150)
plt.show()
print(dict(zip(labels, counts)))

# ── 3. Part 2 — Define classifiers ─────────────────────────────
models = {
    'Perceptron': Perceptron(max_iter=1000, random_state=SEED),
    'Logistic Regression': LogisticRegression(max_iter=1000, random_state=SEED),
    'KNN': KNeighborsClassifier(n_neighbors=5),
    'Gaussian NB': GaussianNB(),
    'Neural Network': MLPClassifier(hidden_layer_sizes=(64,), max_iter=500, random_state=SEED),
}

rkf = RepeatedKFold(n_splits=10, n_repeats=100, random_state=SEED)
results_part2 = {}

for name, model in models.items():
    print(f'Running cross-validation for {name}...')
    scores = cross_val_score(model, X_scaled, y, cv=rkf, scoring='accuracy', n_jobs=-1)
    results_part2[name] = (scores.mean(), scores.std())
    print(f'{name:22s} mean={scores.mean():.4f} std={scores.std():.4f}')

df_part2 = pd.DataFrame(
    [(name, f'{mean:.4f}', f'{std:.4f}') for name, (mean,std) in results_part2.items()],
    columns=['Algorithm', 'Mean Accuracy', 'Std']
)
df_part2.to_csv('part2_results.csv', index=False)

# ── 4. Part 3 — Exhaustive Feature Selection ───────────────────
rkf_fs = RepeatedKFold(n_splits=10, n_repeats=10, random_state=SEED)

def exhaustive_search(model, X, y, feature_names, cv):
    best_mean, best_std, best_subset = -1, None, None
    m = X.shape[1]
    for k in range(1, m+1):
        for combo in combinations(range(m), k):
            cols = list(combo)
            scores = cross_val_score(model, X[:, cols], y, cv=cv, scoring='accuracy', n_jobs=-1)
            if scores.mean() > best_mean:
                best_mean = scores.mean()
                best_std = scores.std()
                best_subset = [feature_names[i] for i in cols]
    return best_subset, best_mean, best_std

results_part3 = {}
for name, model in models.items():
    print(f'\nSearching best features for {name}...')
    subset, mean, std = exhaustive_search(model, X_scaled, y, feature_names, rkf_fs)
    results_part3[name] = (subset, mean, std)
    print(f' Best subset: {subset}')
    print(f' Mean={mean:.4f} Std={std:.4f}')

df_part3 = pd.DataFrame(
    [(name, ', '.join(subset), f'{mean:.4f}', f'{std:.4f}') 
     for name, (subset, mean, std) in results_part3.items()],
    columns=['Algorithm', 'Best Feature Subset', 'Mean Accuracy', 'Std']
)
df_part3.to_csv('part3_results.csv', index=False)

# ── 5. Comparison: All Features vs Best Subset ───────────────
print('\nComparison: All Features vs Best Subset')
print(f'{"Algorithm":<22} {"All Feat Mean":>13} {"Best Sub Mean":>13} {"Delta":>7}')
print('-'*65)
for name in models:
    mean2, _ = results_part2[name]
    _, mean3, _ = results_part3[name]
    delta = mean3 - mean2
    print(f'{name:<22} {mean2:>13.4f} {mean3:>13.4f} {delta:>+7.4f}')

# ── 6. Comparison bar chart ─────────────────────────────────
names = list(models.keys())
means2 = [results_part2[n][0] for n in names]
means3 = [results_part3[n][1] for n in names]

x = np.arange(len(names))
width = 0.35

fig, ax = plt.subplots(figsize=(10,5))
ax.bar(x - width/2, means2, width, label='All Features', color='steelblue')
ax.bar(x + width/2, means3, width, label='Best Subset', color='darkorange')
ax.set_xticks(x)
ax.set_xticklabels(names, rotation=15, ha='right')
ax.set_ylabel('Mean Accuracy')
ax.set_title('Part 2 vs Part 3 — All Features vs Best Subset')
ax.legend()
ax.set_ylim(0,1.05)
plt.tight_layout()
plt.savefig('part2_vs_part3.png', dpi=150)
plt.show()

# ── 7. Generate Filled-in Markdown Report ─────────────────────
report_lines = []

report_lines.append("# CSCI 3329 — Homework 3 Report")
report_lines.append("## Comparing Classification Algorithms with Feature Selection\n")
report_lines.append("---\n")

# Dataset
report_lines.append("## 1. Dataset\n")
report_lines.append("| Property | Value |")
report_lines.append("|----------|-------|")
report_lines.append("| **Name** | Intelligent Media Accelerometer and Gyroscope (IM-AccGyro — 10 Subjects) |")
report_lines.append("| **Source** | Collected from 10 subjects performing 6 activities each |")
report_lines.append(f"| **Samples** | {full_df.shape[0]} |")
report_lines.append(f"| **Features** | {len(feature_names)} (numeric sensor measurements) |")
report_lines.append(f"| **Classes** | {len(le.classes_)} ({', '.join(le.classes_)}) |")
report_lines.append("| **Missing Values** | None |")
report_lines.append("\nThe dataset captures motion data from sensors on arm, leg, and neck.\n")
report_lines.append("### Class Distribution\n")
report_lines.append("![Class Distribution](class_distribution.png)\n")
report_lines.append("---\n")

# Part 2 table
report_lines.append("## 3. Part 2 — Algorithm Comparison\n")
report_lines.append(f"**Protocol:** RepeatedKFold with `n_splits=10`, `n_repeats=100`\n")
report_lines.append("| Algorithm | Mean Accuracy | Std |")
report_lines.append("|-----------|:-------------:|:---:|")
for idx, row in df_part2.iterrows():
    report_lines.append(f"| {row['Algorithm']} | {row['Mean Accuracy']} | {row['Std']} |")
report_lines.append("---\n")

# Part 3 table
report_lines.append("## 4. Part 3 — Feature Selection\n")
report_lines.append("| Algorithm | Best Feature Subset | Mean Accuracy | Std |")
report_lines.append("|-----------|-------------------|:-------------:|:---:|")
for idx, row in df_part3.iterrows():
    report_lines.append(f"| {row['Algorithm']} | {row['Best Feature Subset']} | {row['Mean Accuracy']} | {row['Std']} |")
report_lines.append("---\n")

# Comparison table
report_lines.append("## 5. Comparison: All Features vs Best Subset\n")
report_lines.append("| Algorithm | All Features Mean | Best Subset Mean | Delta |")
report_lines.append("|-----------|:----------------:|:----------------:|:-----:|")
for name in models:
    mean2, _ = results_part2[name]
    _, mean3, _ = results_part3[name]
    delta = mean3 - mean2
    report_lines.append(f"| {name} | {mean2:.4f} | {mean3:.4f} | {delta:+.4f} |")
report_lines.append("![Part 2 vs Part 3](part2_vs_part3.png)\n")

# Save Markdown report
with open('CSCI3329_HW3_Filled_Report.md', 'w') as f:
    f.write('\n'.join(report_lines))

print("Filled-in Markdown report saved as 'CSCI3329_HW3_Filled_Report.md'")
